<?xml version="1.0"?>
<robot name="mechelangelo">

  <!-- =========================
       BASE LINK
       ========================= -->
  <link name="base_link">

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://mechelangelo_description/meshes/base/base.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.50 0.40 0.20"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="12.0"/>
      <inertia
        ixx="0.30"
        ixy="0.0"
        ixz="0.0"
        iyy="0.40"
        iyz="0.0"
        izz="0.50"/>
    </inertial>

  </link>

  <!-- =========================
       LEFT WHEEL LINK
       ========================= -->
  <link name="left_wheel_link">

    <visual>
      <!-- rotate mesh so wheel is aligned correctly -->
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.03"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.03"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia
        ixx="0.002"
        ixy="0.0"
        ixz="0.0"
        iyy="0.001"
        iyz="0.0"
        izz="0.002"/>
    </inertial>

  </link>

  <!-- =========================
       RIGHT WHEEL LINK
       ========================= -->
  <link name="right_wheel_link">

    <visual>
      <!-- rotate mesh so wheel is aligned correctly -->
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://mechelangelo_description/meshes/wheels/wheel.dae" scale="1 1 1"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.03"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia
        ixx="0.002"
        ixy="0.0"
        ixz="0.0"
        iyy="0.001"
        iyz="0.0"
        izz="0.002"/>
    </inertial>

  </link>

  <!-- =========================
       LEFT WHEEL JOINT
       Wheel centre:
       x = 0.11091 forward
       y = +0.20103 left
       z = wheel radius
       ========================= -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="0.11091 0.20103 0.075" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- =========================
       RIGHT WHEEL JOINT
       Wheel centre:
       x = 0.11091 forward
       y = -0.20103 right
       z = wheel radius
       ========================= -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin xyz="0.11091 -0.20103 0.075" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

</robot>