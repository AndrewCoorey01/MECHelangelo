<?xml version="1.0" ?>
<sdf version="1.7">
  <model name="mechelangelo_arm">
    <static>false</static>

    <!-- =========================
         BASE
         ========================= -->
    <link name="base_link">
      <pose>0 0 0.05 0 0 0</pose>
      <gravity>true</gravity>

      <visual name="base_visual">
        <geometry>
          <cylinder>
            <radius>0.08</radius>
            <length>0.10</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1</ambient>
          <diffuse>0.2 0.2 0.2 1</diffuse>
        </material>
      </visual>

      <collision name="base_collision">
        <geometry>
          <cylinder>
            <radius>0.08</radius>
            <length>0.10</length>
          </cylinder>
        </geometry>
      </collision>

      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.01</ixx>
          <iyy>0.01</iyy>
          <izz>0.01</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
    </link>

    <!-- =========================
         SHOULDER JOINT 1
         yaw servo body
         ========================= -->
    <link name="joint1_link">
      <pose>0 0 0.13 0 0 0</pose>
      <gravity>false</gravity>

      <visual name="joint1_visual">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>1 0 0 1</ambient>
          <diffuse>1 0 0 1</diffuse>
        </material>
      </visual>

      <collision name="joint1_collision">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
      </collision>

      <inertial>
        <mass>0.30</mass>
        <inertia>
          <ixx>0.0005</ixx>
          <iyy>0.0005</iyy>
          <izz>0.0003</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
    </link>

    <joint name="joint1" type="revolute">
      <parent>base_link</parent>
      <child>joint1_link</child>
      <pose>0 0 0.08 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-3.1416</lower>
          <upper>3.1416</upper>
          <effort>20</effort>
          <velocity>1.5</velocity>
        </limit>
        <dynamics>
          <damping>0.1</damping>
        </dynamics>
      </axis>
    </joint>

    <!-- =========================
         SHOULDER JOINT 2
         pitch servo body
         directly attached to joint1
         ========================= -->
    <link name="joint2_link">
      <pose>0 0 0.16 0 1.5708 0</pose>
      <gravity>false</gravity>

      <visual name="joint2_visual">
        <geometry>
          <cylinder>
            <radius>0.045</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>1 0 0 1</ambient>
          <diffuse>1 0 0 1</diffuse>
        </material>
      </visual>

      <collision name="joint2_collision">
        <geometry>
          <cylinder>
            <radius>0.045</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
      </collision>

      <inertial>
        <mass>0.25</mass>
        <inertia>
          <ixx>0.0004</ixx>
          <iyy>0.0004</iyy>
          <izz>0.0002</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
    </link>

    <joint name="joint2" type="revolute">
      <parent>joint1_link</parent>
      <child>joint2_link</child>
      <pose>0 0 0.03 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-3.1416</lower>
          <upper>0</upper>
          <effort>15</effort>
          <velocity>1.5</velocity>
        </limit>
        <dynamics>
          <damping>0.1</damping>
        </dynamics>
      </axis>
    </joint>

    <!-- =========================
         LINK 1
         upper arm
         straight along +X by default
         ========================= -->
    <link name="link1">
      <pose>0.14 0 0.16 0 1.5708 0</pose>
      <gravity>false</gravity>

      <visual name="link1_visual">
        <geometry>
          <cylinder>
            <radius>0.025</radius>
            <length>0.28</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0 0 1 1</ambient>
          <diffuse>0 0 1 1</diffuse>
        </material>
      </visual>

      <collision name="link1_collision">
        <geometry>
          <cylinder>
            <radius>0.025</radius>
            <length>0.28</length>
          </cylinder>
        </geometry>
      </collision>

      <inertial>
        <mass>0.35</mass>
        <inertia>
          <ixx>0.0020</ixx>
          <iyy>0.0020</iyy>
          <izz>0.0002</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
    </link>

    <joint name="fixed_joint2_to_link1" type="fixed">
      <parent>joint2_link</parent>
      <child>link1</child>
      <pose>0.14 0 0 0 0 0</pose>
    </joint>

    <!-- =========================
         ELBOW JOINT 3
         pitch servo body
         directly at end of link1
         ========================= -->
    <link name="joint3_link">
      <pose>0.28 0 0.16 0 1.5708 0</pose>
      <gravity>false</gravity>

      <visual name="joint3_visual">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>1 0 0 1</ambient>
          <diffuse>1 0 0 1</diffuse>
        </material>
      </visual>

      <collision name="joint3_collision">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
      </collision>

      <inertial>
        <mass>0.20</mass>
        <inertia>
          <ixx>0.0003</ixx>
          <iyy>0.0003</iyy>
          <izz>0.00015</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
    </link>

    <joint name="joint3" type="revolute">
      <parent>link1</parent>
      <child>joint3_link</child>
      <pose>0.14 0 0 0 0 0</pose>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>-3.1416</lower>
          <upper>3.1416</upper>
          <effort>10</effort>
          <velocity>1.5</velocity>
        </limit>
        <dynamics>
          <damping>0.1</damping>
        </dynamics>
      </axis>
    </joint>

    <!-- =========================
         ELBOW JOINT 4
         roll servo body
         directly attached to joint3
         ========================= -->
    <link name="joint4_link">
      <pose>0.31 0 0.16 1.5708 0 0</pose>
      <gravity>false</gravity>

      <visual name="joint4_visual">
        <geometry>
          <cylinder>
            <radius>0.035</radius>
            <length>0.05</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>1 0 0 1</ambient>
          <diffuse>1 0 0 1</diffuse>
        </material>
      </visual>

      <collision name="joint4_collision">
        <geometry>
          <cylinder>
            <radius>0.035</radius>
            <length>0.05</length>
          </cylinder>
        </geometry>
      </collision>

      <inertial>
        <mass>0.15</mass>
        <inertia>
          <ixx>0.0002</ixx>
          <iyy>0.0002</iyy>
          <izz>0.0001</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
    </link>

    <joint name="joint4" type="revolute">
      <parent>joint3_link</parent>
      <child>joint4_link</child>
      <pose>0.03 0 0 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1.57</lower>
          <upper>1.57</upper>
          <effort>8</effort>
          <velocity>1.5</velocity>
        </limit>
        <dynamics>
          <damping>0.05</damping>
        </dynamics>
      </axis>
    </joint>

    <!-- =========================
         LINK 2
         lower arm
         straight continuation of link1
         ========================= -->
    <link name="link2">
      <pose>0.43 0 0.16 0 1.5708 0</pose>
      <gravity>false</gravity>

      <visual name="link2_visual">
        <geometry>
          <cylinder>
            <radius>0.022</radius>
            <length>0.24</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0 0 1 1</ambient>
          <diffuse>0 0 1 1</diffuse>
        </material>
      </visual>

      <collision name="link2_collision">
        <geometry>
          <cylinder>
            <radius>0.022</radius>
            <length>0.24</length>
          </cylinder>
        </geometry>
      </collision>

      <inertial>
        <mass>0.25</mass>
        <inertia>
          <ixx>0.0010</ixx>
          <iyy>0.0010</iyy>
          <izz>0.0001</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
    </link>

    <joint name="fixed_joint4_to_link2" type="fixed">
      <parent>joint4_link</parent>
      <child>link2</child>
      <pose>0.12 0 0 0 0 0</pose>
    </joint>

  </model>
</sdf>