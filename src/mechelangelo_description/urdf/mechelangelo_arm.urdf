<?xml version="1.0"?>
<robot name="mechelangelo_arm">

  <!-- =========================
       MATERIALS
       ========================= -->
  <material name="red">
    <color rgba="1 0 0 1"/>
  </material>

  <material name="blue">
    <color rgba="0 0 1 1"/>
  </material>

  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1"/>
  </material>

  <!-- =========================
       ROOT LINK
       ========================= -->
  <link name="base_footprint"/>

  <!-- =========================
       BASE
       ========================= -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.10"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.10"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia
        ixx="0.01" ixy="0.0" ixz="0.0"
        iyy="0.01" iyz="0.0"
        izz="0.01"/>
    </inertial>
  </link>

  <joint name="base_fixed_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <!-- =========================
       SHOULDER JOINT 1
       ========================= -->
  <link name="joint1_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.06"/>
      </geometry>
      <material name="red"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.06"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.30"/>
      <inertia
        ixx="0.0005" ixy="0.0" ixz="0.0"
        iyy="0.0005" iyz="0.0"
        izz="0.0003"/>
    </inertial>
  </link>

  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="joint1_link"/>
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="20" velocity="1.5"/>
    <dynamics damping="0.1"/>
  </joint>

  <!-- =========================
       SHOULDER JOINT 2
       ========================= -->
  <link name="joint2_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.045" length="0.06"/>
      </geometry>
      <material name="red"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.045" length="0.06"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.25"/>
      <inertia
        ixx="0.0004" ixy="0.0" ixz="0.0"
        iyy="0.0004" iyz="0.0"
        izz="0.0002"/>
    </inertial>
  </link>

  <joint name="joint2" type="revolute">
    <parent link="joint1_link"/>
    <child link="joint2_link"/>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.1416" upper="0" effort="15" velocity="1.5"/>
    <dynamics damping="0.1"/>
  </joint>

  <!-- =========================
       LINK 1
       ========================= -->
  <link name="link1">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.28"/>
      </geometry>
      <material name="blue"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.28"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.35"/>
      <inertia
        ixx="0.0020" ixy="0.0" ixz="0.0"
        iyy="0.0020" iyz="0.0"
        izz="0.0002"/>
    </inertial>
  </link>

  <joint name="joint2_to_link1" type="fixed">
    <parent link="joint2_link"/>
    <child link="link1"/>
    <origin xyz="0.14 0 0" rpy="0 0 0"/>
  </joint>

  <!-- =========================
       ELBOW JOINT 3
       ========================= -->
  <link name="joint3_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.06"/>
      </geometry>
      <material name="red"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.06"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.20"/>
      <inertia
        ixx="0.0003" ixy="0.0" ixz="0.0"
        iyy="0.0003" iyz="0.0"
        izz="0.00015"/>
    </inertial>
  </link>

  <joint name="joint3" type="revolute">
    <parent link="link1"/>
    <child link="joint3_link"/>
    <origin xyz="0.14 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.1416" upper="3.1416" effort="10" velocity="1.5"/>
    <dynamics damping="0.1"/>
  </joint>

  <!-- =========================
       ELBOW JOINT 4
       ========================= -->
  <link name="joint4_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.05"/>
      </geometry>
      <material name="red"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.05"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia
        ixx="0.0002" ixy="0.0" ixz="0.0"
        iyy="0.0002" iyz="0.0"
        izz="0.0001"/>
    </inertial>
  </link>

  <joint name="joint4" type="revolute">
    <parent link="joint3_link"/>
    <child link="joint4_link"/>
    <origin xyz="0.03 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="8" velocity="1.5"/>
    <dynamics damping="0.05"/>
  </joint>

  <!-- =========================
       LINK 2
       ========================= -->
  <link name="link2">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.022" length="0.24"/>
      </geometry>
      <material name="blue"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.022" length="0.24"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.25"/>
      <inertia
        ixx="0.0010" ixy="0.0" ixz="0.0"
        iyy="0.0010" iyz="0.0"
        izz="0.0001"/>
    </inertial>
  </link>

  <joint name="joint4_to_link2" type="fixed">
    <parent link="joint4_link"/>
    <child link="link2"/>
    <origin xyz="0.12 0 0" rpy="0 0 0"/>
  </joint>

  <!-- =========================
       GAZEBO: DISABLE GRAVITY
       ========================= -->
  <gazebo reference="joint1_link">
    <gravity>false</gravity>
  </gazebo>

  <gazebo reference="joint2_link">
    <gravity>false</gravity>
  </gazebo>

  <gazebo reference="link1">
    <gravity>false</gravity>
  </gazebo>

  <gazebo reference="joint3_link">
    <gravity>false</gravity>
  </gazebo>

  <gazebo reference="joint4_link">
    <gravity>false</gravity>
  </gazebo>

  <gazebo reference="link2">
    <gravity>false</gravity>
  </gazebo>

</robot>