    </joint>

    <link name="left_link2">
      <!-- <pose>0.43 0.28 1.49 0 1.5708 0</pose><gravity>false</gravity> -->
      <pose>0.43 0.23 1.38 0 1.5708 0</pose><gravity>false</gravity>
      <visual name="left_link2_visual"><geometry><cylinder><radius>0.022</radius><length>0.24</length></cylinder></geometry><material><ambient>0 0 1 1</ambient><diffuse>0 0 1 1</diffuse></material></visual>
