<?xml version="1.0"?>
<sdf version="1.7">
  <model name="mechelangelo_dual_arm">
    <pose>0 0 0 0 0 0</pose>

    <!-- =========================
         BASE
         ========================= -->
    <link name="base_link">
      <inertial>
        <pose>0 0 0.10 0 0 0</pose>
        <mass>12.0</mass>
        <inertia>
          <ixx>0.30</ixx><ixy>0.0</ixy><ixz>0.0</ixz>
          <iyy>0.40</iyy><iyz>0.0</iyz>
          <izz>0.50</izz>
        </inertia>
      </inertial>

      <collision name="base_collision">
        <pose>0 0 0.10 0 0 0</pose>
        <geometry>
          <mesh><uri>model://mechelangelo/meshes/base/base.dae</uri><scale>1 1 1</scale></mesh>
        </geometry>
      </collision>

      <visual name="base_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh><uri>model://mechelangelo/meshes/base/base.dae</uri><scale>1 1 1</scale></mesh>
        </geometry>
      </visual>
    </link>

    <link name="wheel_left_link">
      <inertial>
        <pose>0.11091 0.20103 0.075 0 0 0</pose>
        <mass>1.0</mass>
        <inertia><ixx>0.002</ixx><ixy>0.0</ixy><ixz>0.0</ixz><iyy>0.001</iyy><iyz>0.0</iyz><izz>0.002</izz></inertia>
      </inertial>
      <collision name="wheel_left_collision">
        <pose>0.11091 0.20103 0.075 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.075</radius><length>0.03</length></cylinder></geometry>
      </collision>
      <visual name="wheel_left_visual">
        <pose>0.11091 0.20103 0.075 0 0 0</pose>
        <geometry><mesh><uri>model://mechelangelo/meshes/wheels/wheel.dae</uri><scale>1 1 1</scale></mesh></geometry>
      </visual>
    </link>

    <link name="wheel_right_link">
      <inertial>
        <pose>0.11091 -0.20103 0.075 0 0 0</pose>
        <mass>1.0</mass>
        <inertia><ixx>0.002</ixx><ixy>0.0</ixy><ixz>0.0</ixz><iyy>0.001</iyy><iyz>0.0</iyz><izz>0.002</izz></inertia>
      </inertial>
      <collision name="wheel_right_collision">
        <pose>0.11091 -0.20103 0.075 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.075</radius><length>0.03</length></cylinder></geometry>
      </collision>
      <visual name="wheel_right_visual">
        <pose>0.11091 -0.20103 0.075 0 0 0</pose>
        <geometry><mesh><uri>model://mechelangelo/meshes/wheels/wheel.dae</uri><scale>1 1 1</scale></mesh></geometry>
      </visual>
    </link>

    <link name="caster_link">
      <inertial>
        <pose>-0.18 0.0 0.03 0 0 0</pose>
        <mass>0.2</mass>
        <inertia><ixx>0.0001</ixx><ixy>0.0</ixy><ixz>0.0</ixz><iyy>0.0001</iyy><iyz>0.0</iyz><izz>0.0001</izz></inertia>
      </inertial>
      <collision name="caster_collision">
        <pose>-0.18 0.0 0.03 0 0 0</pose>
        <geometry><sphere><radius>0.03</radius></sphere></geometry>
      </collision>
      <visual name="caster_visual">
        <pose>-0.18 0.0 0.03 0 0 0</pose>
        <geometry><sphere><radius>0.03</radius></sphere></geometry>
      </visual>
    </link>

    <link name="imu_link">
      <sensor name="mechelangelo_imu" type="imu">
        <always_on>true</always_on>
        <update_rate>100</update_rate>
        <plugin name="mechelangelo_imu_plugin" filename="libgazebo_ros_imu_sensor.so">
          <ros><remapping>~/out:=/imu</remapping></ros>
        </plugin>
      </sensor>
    </link>

    <link name="base_scan">
      <visual name="lidar_visual">
        <pose>0 0 0.280 0 0 0</pose>
        <geometry><mesh><uri>model://mechelangelo/meshes/sensors/lds.dae</uri><scale>1 1 1</scale></mesh></geometry>
      </visual>

      <sensor name="mechelangelo_lidar" type="ray">
        <always_on>true</always_on>
        <visualize>true</visualize>
        <pose>0 0 0.280 0 0 0</pose>
        <update_rate>10</update_rate>
        <ray>
          <scan><horizontal><samples>720</samples><resolution>1</resolution><min_angle>-3.14159</min_angle><max_angle>3.14159</max_angle></horizontal></scan>
          <range><min>0.12</min><max>8.0</max><resolution>0.01</resolution></range>
        </ray>
        <plugin name="mechelangelo_laserscan_plugin" filename="libgazebo_ros_ray_sensor.so">
          <ros><remapping>~/out:=/scan</remapping></ros>
          <output_type>sensor_msgs/LaserScan</output_type>
          <frame_name>base_scan</frame_name>
        </plugin>
      </sensor>
    </link>

    <link name="camera_link">
      <visual name="camera_visual">
        <pose>0 0 1.480 0 0 0</pose>
        <geometry><box><size>0.015 0.030 0.027</size></box></geometry>
      </visual>
    </link>

    <link name="camera_rgb_frame"/>
    <link name="camera_rgb_optical_frame">
      <pose>0 0 1.480 0 0 0</pose>
      <sensor name="mechelangelo_camera" type="camera">
        <always_on>true</always_on>
        <visualize>false</visualize>
        <update_rate>15</update_rate>
        <camera>
          <horizontal_fov>1.3962634</horizontal_fov>
          <image><width>640</width><height>480</height><format>R8G8B8</format></image>
          <clip><near>0.05</near><far>20.0</far></clip>
        </camera>
        <plugin name="mechelangelo_camera_plugin" filename="libgazebo_ros_camera.so">
          <ros>
            <remapping>~/image_raw:=/camera/image_raw</remapping>
            <remapping>~/camera_info:=/camera/camera_info</remapping>
          </ros>
        </plugin>
      </sensor>
    </link>

    <joint name="left_wheel_joint" type="revolute">
      <parent>base_link</parent><child>wheel_left_link</child>
      <pose>0.11091 0.20103 0.075 0 0 0</pose>
      <axis><xyz>0 1 0</xyz></axis>
    </joint>

    <joint name="right_wheel_joint" type="revolute">
      <parent>base_link</parent><child>wheel_right_link</child>
      <pose>0.11091 -0.20103 0.075 0 0 0</pose>
      <axis><xyz>0 1 0</xyz></axis>
    </joint>

    <joint name="caster_joint" type="fixed">
      <parent>base_link</parent><child>caster_link</child>
      <pose>-0.18 0.0 0.03 0 0 0</pose>
    </joint>

    <joint name="imu_joint" type="fixed">
      <parent>base_link</parent><child>imu_link</child>
      <pose>0.0 0 0.068 0 0 0</pose>
    </joint>

    <joint name="scan_joint" type="fixed">
      <parent>base_link</parent><child>base_scan</child>
      <pose>0 0 0.280 0 0 0</pose>
    </joint>

    <joint name="camera_joint" type="fixed">
      <parent>base_link</parent><child>camera_link</child>
      <pose>0 0 1.480 0 0 0</pose>
    </joint>

    <joint name="camera_rgb_joint" type="fixed">
      <parent>camera_link</parent><child>camera_rgb_frame</child>
      <pose>0 0 0 0 0 0</pose>
    </joint>

    <joint name="camera_rgb_optical_joint" type="fixed">
      <parent>camera_rgb_frame</parent><child>camera_rgb_optical_frame</child>
      <pose>0 0 0 -1.5708 0 -1.5708</pose>
    </joint>

    <!-- =========================
         LEFT ARM
         ========================= -->
    <link name="left_arm_base_link">
      <pose>0 0.15 1.38 1.5708 0 0</pose>
      <gravity>false</gravity>
      <visual name="left_arm_base_visual">
        <geometry><cylinder><radius>0.08</radius><length>0.10</length></cylinder></geometry>
        <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.2 0.2 0.2 1</diffuse></material>
      </visual>
      <collision name="left_arm_base_collision">
        <geometry><cylinder><radius>0.08</radius><length>0.10</length></cylinder></geometry>
      </collision>
      <inertial><mass>2.0</mass><inertia><ixx>0.01</ixx><iyy>0.01</iyy><izz>0.01</izz><ixy>0.0</ixy><ixz>0.0</ixz><iyz>0.0</iyz></inertia></inertial>
    </link>

    <joint name="left_arm_mount_joint" type="fixed">
      <parent>base_link</parent><child>left_arm_base_link</child>
      <!-- <pose>0 0.15 1.38 1.5708 0 0</pose> -->
    </joint>

    <link name="left_joint1_link">
      <!-- <pose>0 0.28 1.46 0 0 0</pose><gravity>false</gravity> -->
      <pose>0 0.15 1.38 0 0 0</pose><gravity>false</gravity>
      <visual name="left_joint1_visual"><geometry><cylinder><radius>0.04</radius><length>0.06</length></cylinder></geometry><material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual>
      <collision name="left_joint1_collision"><geometry><cylinder><radius>0.04</radius><length>0.06</length></cylinder></geometry></collision>
      <inertial><mass>0.30</mass><inertia><ixx>0.0005</ixx><iyy>0.0005</iyy><izz>0.0003</izz><ixy>0.0</ixy><ixz>0.0</ixz><iyz>0.0</iyz></inertia></inertial>
    </link>

    <joint name="left_joint1" type="revolute">
      <parent>left_arm_base_link</parent><child>left_joint1_link</child>
      <!-- <pose>0 0 0.08 0 0 0</pose> -->
      <axis><xyz>0 0 1</xyz><limit><lower>-3.1416</lower><upper>3.1416</upper><effort>20</effort><velocity>1.5</velocity></limit><dynamics><damping>0.1</damping></dynamics></axis>
    </joint>

    <link name="left_joint2_link">
      <!-- <pose>0 0.28 1.49 0 1.5708 0</pose><gravity>false</gravity> -->
      <pose>0 0.23 1.38 0 1.5708 0</pose><gravity>false</gravity>
      <visual name="left_joint2_visual"><geometry><cylinder><radius>0.045</radius><length>0.06</length></cylinder></geometry><material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual>
      <collision name="left_joint2_collision"><geometry><cylinder><radius>0.045</radius><length>0.06</length></cylinder></geometry></collision>
      <inertial><mass>0.25</mass><inertia><ixx>0.0004</ixx><iyy>0.0004</iyy><izz>0.0002</izz><ixy>0.0</ixy><ixz>0.0</ixz><iyz>0.0</iyz></inertia></inertial>
    </link>

    <joint name="left_joint2" type="revolute">
      <parent>left_joint1_link</parent><child>left_joint2_link</child>
      <!-- <pose>0 0 0.03 0 0 0</pose> -->
      <axis><xyz>0 1 0</xyz><limit><lower>-3.1416</lower><upper>0</upper><effort>15</effort><velocity>1.5</velocity></limit><dynamics><damping>0.1</damping></dynamics></axis>
    </joint>

    <link name="left_link1">
      <!-- <pose>0.14 0.28 1.49 0 1.5708 0</pose><gravity>false</gravity> -->
      <pose>0.14 0.23 1.38 0 1.5708 0</pose><gravity>false</gravity>
      <visual name="left_link1_visual"><geometry><cylinder><radius>0.025</radius><length>0.28</length></cylinder></geometry><material><ambient>0 0 1 1</ambient><diffuse>0 0 1 1</diffuse></material></visual>
      <collision name="left_link1_collision"><geometry><cylinder><radius>0.025</radius><length>0.28</length></cylinder></geometry></collision>
      <inertial><mass>0.35</mass><inertia><ixx>0.0020</ixx><iyy>0.0020</iyy><izz>0.0002</izz><ixy>0.0</ixy><ixz>0.0</ixz><iyz>0.0</iyz></inertia></inertial>
    </link>

    <joint name="left_joint2_to_link1" type="fixed">
      <parent>left_joint2_link</parent><child>left_link1</child>
      <!-- <pose>0.14 0 0 0 0 0</pose> -->
    </joint>

    <link name="left_joint3_link">
      <!-- <pose>0.28 0.28 1.49 0 1.5708 0</pose><gravity>false</gravity> -->
