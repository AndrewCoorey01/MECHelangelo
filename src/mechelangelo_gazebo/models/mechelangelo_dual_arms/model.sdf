    </link>
    
    <joint name="right_joint4_to_link2" type="fixed">
      <parent>right_joint4_link</parent><child>right_link2</child>
      <!-- <pose>0.12 0 0 0 0 0</pose> -->
    </joint>

    <!-- =========================
         PLUGINS
         ========================= -->
    <plugin name="mechelangelo_diff_drive" filename="libgazebo_ros_diff_drive.so">
      <update_rate>50</update_rate>
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.40206</wheel_separation>
      <wheel_diameter>0.15</wheel_diameter>
      <max_wheel_torque>20.0</max_wheel_torque>
      <max_wheel_acceleration>5.0</max_wheel_acceleration>
      <command_topic>cmd_vel</command_topic>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
    </plugin>

    <plugin name="mechelangelo_joint_state" filename="libgazebo_ros_joint_state_publisher.so">
      <ros><remapping>~/out:=/joint_states</remapping></ros>
      <update_rate>30</update_rate>
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
      <joint_name>left_joint1</joint_name>
      <joint_name>left_joint2</joint_name>
      <joint_name>left_joint3</joint_name>
      <joint_name>left_joint4</joint_name>
      <joint_name>right_joint1</joint_name>
      <joint_name>right_joint2</joint_name>
      <joint_name>right_joint3</joint_name>
      <joint_name>right_joint4</joint_name>
    </plugin>

  </model>
</sdf>