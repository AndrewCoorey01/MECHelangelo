      <!-- <pose>0.14 0 0 0 0 0</pose> -->
      <axis><xyz>1 0 0</xyz><limit><lower>-3.1416</lower><upper>3.1416</upper><effort>10</effort><velocity>1.5</velocity></limit><dynamics><damping>0.1</damping></dynamics></axis>
    </joint>

    <link name="left_joint4_link">
      <!-- <pose>0.31 0.28 1.49 1.5708 0 0</pose><gravity>false</gravity> -->
